# ============================================================
# PartFinder — Environment Variables Template
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ============================================================

# ----------------------------------------------------------
# Google AI / Gemini (required for agent reasoning)
# Obtain a free key at https://aistudio.google.com/apikey
# Free tier: ~15 req/min, ~1,500 req/day for Flash models.
# ----------------------------------------------------------
GOOGLE_API_KEY=your_google_api_key_here

# Override the default model if needed (default: gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash

# ----------------------------------------------------------
# SerpApi (required for live Home Depot / Amazon search)
# Obtain a key at https://serpapi.com/
# Not required when DEMO_MODE=true.
# ----------------------------------------------------------
SERPAPI_KEY=your_serpapi_key_here

# ----------------------------------------------------------
# Demo / Development mode
# Set to "true" to use cached fixture data instead of live
# SerpApi calls. Useful for recording demos without quota.
# Default: false (live mode)
# ----------------------------------------------------------
DEMO_MODE=false

# ----------------------------------------------------------
# Server ports
# ----------------------------------------------------------
BACKEND_PORT=8000
MCP_SERVER_PORT=8001

# ----------------------------------------------------------
# Frontend (used by Vite dev server proxy)
# ----------------------------------------------------------
VITE_API_URL=http://localhost:8000
